{
  "$description": "Console ADS — semantic tokens (--sys-*), Light theme. This is :root. UI references THESE, never --ref-*. Accent slots hold the default (blue) profile; profiles.json remaps them per [data-accent].",
  "$version": "1.1.0",
  "$theme": "light",
  "background": {
    "canvas": "#F9FAFB",
    "surface": "#FFFFFF",
    "raised": "#FFFFFF",
    "sunken": "#F2F4F6",
    "hover": "#F2F4F6",
    "overlay": "rgba(25,31,40,0.52)"
  },
  "content": {
    "primary": "#191F28",
    "secondary": "#4E5968",
    "tertiary": "#8B95A1",
    "disabled": "#B0B8C1",
    "inverse": "#FFFFFF",
    "accent": "#1B64DA",
    "on-accent": "#FFFFFF"
  },
  "border": {
    "subtle": "#F2F4F6",
    "default": "#E5E8EB",
    "strong": "#D1D6DB",
    "focus": "#3182F6"
  },
  "accent": {
    "solid": "#3182F6",
    "hover": "#2272EB",
    "active": "#1B64DA",
    "subtle": "#EBF3FE",
    "muted": "#A9CBFB",
    "content": "#1B64DA",
    "on-solid": "#FFFFFF"
  },
  "status": {
    "success": "#12B886", "success-subtle": "#E6F9F0", "success-content": "#0A7C5A",
    "warning": "#F59F00", "warning-subtle": "#FFF7E6", "warning-content": "#A16207",
    "danger":  "#E03131", "danger-subtle":  "#FFECEC", "danger-content":  "#C92A2A",
    "info":    "#3182F6", "info-subtle":    "#EBF3FE", "info-content":    "#1B64DA"
  },
  "viz": {
    "1": "#3182F6", "2": "#12B886", "3": "#F59F00", "4": "#845EF7",
    "5": "#4DABF7", "6": "#20C997", "7": "#FF6B6B", "8": "#868E96",
    "grid": "#F2F4F6", "axis": "#8B95A1"
  }
}
