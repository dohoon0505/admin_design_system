{
  "$description": "Console ADS — semantic tokens (--sys-*), Dark theme overrides. Applied via [data-theme=\"dark\"]. Same token names as Light, different values (principle 02: one surface, two themes). Shadows also darken.",
  "$version": "1.1.0",
  "$theme": "dark",
  "background": {
    "canvas": "#12161B",
    "surface": "#191F28",
    "raised": "#252A32",
    "sunken": "#0A0D11",
    "hover": "#232A33",
    "overlay": "rgba(0,0,0,0.60)"
  },
  "content": {
    "primary": "#F2F4F6",
    "secondary": "#B0B8C1",
    "tertiary": "#8B95A1",
    "disabled": "#4E5968",
    "inverse": "#191F28",
    "accent": "#7BAEF8",
    "on-accent": "#12161B"
  },
  "border": {
    "subtle": "#252A32",
    "default": "#333D4B",
    "strong": "#4E5968",
    "focus": "#4E92F7"
  },
  "accent": {
    "solid": "#4E92F7",
    "hover": "#7BAEF8",
    "active": "#A9CBFB",
    "subtle": "#12233D",
    "muted": "#1957B8",
    "content": "#7BAEF8",
    "on-solid": "#12161B"
  },
  "status": {
    "success": "#20C997", "success-subtle": "#0C2A22", "success-content": "#38D9A9",
    "warning": "#FCC419", "warning-subtle": "#332811", "warning-content": "#FFD43B",
    "danger":  "#FF6B6B", "danger-subtle":  "#341A1E", "danger-content":  "#FF8787",
    "info":    "#4DABF7", "info-subtle":    "#12233D", "info-content":    "#74C0FC"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(0,0,0,0.4)",
    "sm": "0 1px 3px rgba(0,0,0,0.4), 0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 14px rgba(0,0,0,0.45), 0 2px 4px rgba(0,0,0,0.35)",
    "lg": "0 10px 28px rgba(0,0,0,0.5), 0 4px 10px rgba(0,0,0,0.4)",
    "xl": "0 20px 56px rgba(0,0,0,0.6), 0 8px 20px rgba(0,0,0,0.45)"
  },
  "viz": { "grid": "#252A32", "axis": "#8B95A1" }
}
